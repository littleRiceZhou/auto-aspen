# ============ 智能体 / OpenAI 兼容接口 ============
# 必填：自然语言参数解析、流式对话；留空则智能体仅返回配置提示
OPENAI_API_KEY=xxxx

# 可选：兼容 OpenAI 的网关 Base URL（末尾勿加 /chat/completions）
OPENAI_BASE_URL=https://ph8.co/v1

# 结构化抽参与非流式 parse 使用的模型
AGENT_MODEL=gpt-4o

# ============ Aspen Plus ============
# APWZ 案例路径（综合仿真与智能体最终跑数共用）
ASPEN_APWZ_FILE_PATH=./models/RE-Expander.apwz

# 设为 1/true/yes/on：无 Aspen 真机时用数学近似走通全流程（开发机/CI）
AUTO_ASPEN_MOCK=0

# 透平一维与 turbExpander_1D.m：cm3=c1*(0.4-r*0.05) 的 r。留空=与 M 一样每次随机；
# 设为 0~1 固定（如 0.5=旧中点、便于与单次数值对齐；与 MATLAB 对齐时可写本次 rand）
# AUTO_ASPEN_TE1D_CM3=0.5

